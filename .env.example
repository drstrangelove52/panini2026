# Kopieren nach .env und anpassen

# Domain (wird erst benötigt wenn panini.pob.li eingerichtet ist)
DOMAIN=panini.pob.li

# Sicherer zufälliger Schlüssel für JWT-Token-Signierung
# Generieren mit: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET

# Admin-Account (wird beim ersten Start erstellt)
ADMIN_NICKNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ntfy.sh Push-Benachrichtigungen (optional)
# Beispiel: https://ntfy.sh/dein-geheimer-topic-name
# Topic sollte nicht erratbar sein (z.B. panini-admin-x7k2m9)
NTFY_URL=https://ntfy.sh/REPLACE_WITH_YOUR_TOPIC

# E-Mail für Let's Encrypt (Traefik)
ACME_EMAIL=REPLACE_WITH_YOUR_EMAIL
